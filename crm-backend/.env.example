# Server Configuration
PORT=8000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# Encryption Configuration
ENCRYPTION_KEY=your-32-character-encryption-key-here
ENCRYPTION_ALGORITHM=aes-256-gcm

# MySQL Database Configuration
DB_HOST=sample_host
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=....
DB_NAME=sample_database
DB_SSL=true

# Admissions Database (Same AWS Instance, Different Database)
DB_NAME_ADMISSIONS=admissions_db

# Redis Configuration (optional, for token/session management)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# CORS Configuration (comma-separated for multiple origins)
# Production URLs are automatically added in server.js
# Add additional development/testing origins here if needed
CORS_ORIGIN=http://localhost:5173,http://localhost:3001

# Application URLs
FRONTEND_URL=http://localhost:5173
PORTAL_DEV_URL=http://localhost:3001

# Production URLs (automatically included in CORS, no need to add to CORS_ORIGIN)
# - https://crm.pydah.edu.in (Production CRM frontend)
# - https://pydahsdms.vercel.app (Production student portal)

# HRMS SSO: MongoDB connection for resolving CRM users to HRMS User/Employee (optional)
# When set, verify-token for portalId=hrms will look up the user in HRMS and return HRMS _id as userId
# HRMS_MONGO_URI=mongodb://user:pass@host:27017/hrms

# Hostel: MongoDB connection for hostel software (optional, separate database)
# When set, backend can connect to hostel DB for SSO/user resolution (passwords and schema TBD)
# HOSTEL_MONGO_URI=mongodb://user:pass@host:27017/hostel
